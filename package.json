  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "googleapis": "^173.0.0",
    "open": "^9.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "typescript": "^5.8.3",
    "undici-types": "^7.8.0"
  }
}
