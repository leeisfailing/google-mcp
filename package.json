{
  "name": "google-mcp",
  "version": "1.0.0",
  "description": "MCP server for Google Workspace (330 tools across 10 APIs: Drive, Calendar, Docs, Sheets, Slides, Forms, Classroom, Meet, Labels, Gmail)",
  "type": "module",
  "main": "build/index.js",
  "scripts": {
